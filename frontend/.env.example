# Backend API Base URL
VITE_API_URL=http://localhost:5001/api

# Firebase Client SDK Configuration
# Note: For local development, if these are empty, the frontend will automatically run
# in mock-auth mode (so you can test it without setting up a Firebase project).
VITE_FIREBASE_API_KEY=AIzaSyAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Payment Gateways (Sandbox / Public Keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
